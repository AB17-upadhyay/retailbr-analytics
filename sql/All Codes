  COUNTIF(order_delivered_customer_date IS NULL)    AS null_delivery_date,
  COUNTIF(order_estimated_delivery_date IS NULL)    AS null_estimated_date,
  COUNTIF(order_status = 'delivered'
          AND order_delivered_customer_date IS NULL) AS delivered_missing_date
FROM `retailbr-analytics.stg_olist.orders`;

